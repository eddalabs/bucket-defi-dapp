  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm copy-contract-keys && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "copy-contract-keys": "mkdir -p ./public/midnight/mini-private-buyer/keys ./public/midnight/mini-private-buyer/zkir && (test -d ../private-buyer-contract/src/managed/mini-private-buyer/keys && cp -r ../private-buyer-contract/src/managed/mini-private-buyer/keys/* ./public/midnight/mini-private-buyer/keys || true) && (test -d ../private-buyer-contract/src/managed/mini-private-buyer/zkir && cp -r ../private-buyer-contract/src/managed/mini-private-buyer/zkir/* ./public/midnight/mini-private-buyer/zkir || true)"
  },
