// Edda Labs Compact Contracts v0.0.1
pragma language_version >= 0.20;

/**
* @description: Private Buyer contract - eliminates buyer intent exposure by replacing buckets with a direct NFT pool purchase model. Sellers list NFTs in a pool, buyers purchase them directly in a single transaction. NFT ownership post-purchase is stored as a hash commitment (ZK-provable).
*
* @notice: Access control module manages roles: Admin(0), Minter(1), PoolOperator(2), Verifier(3).
*
* @notice: Best Practices
* - Modules are self-contained (logic-module + Initializable-module + Pausable-module).
* - All initializing circuits are called within the constructor.
* - Inter-module state flows through the top-level contract when circuits depend on multiple module states.
* - Utils modules only contain pure circuits.
*
* @notice Missing Features and Improvements:
* - Events
* - Contract-to-Contract Communication
*
* @notice: Design patterns
* - Initializable
* - Pausable
* - Concurrency-safe: use of simple, granular and critical ADTs
* - Low fees: optimized circuits & minimal ADTs interactions
* - High performance: use events to build complex queries offchain
*/

import CompactStandardLibrary;

import "./modules/access-control/AccessControl" prefix AccessControl_;

import "./modules/identity/Identity" prefix Identity_;

import "./modules/token-nft/NonFungibleToken" prefix NonFungibleToken_;

import "./modules/nft-pool/NFTPool" prefix NFTPool_;

///////////////////////////////////////////////////////////////////////////////
// PUBLIC STATE FROM MODULES
///////////////////////////////////////////////////////////////////////////////

export { AccessControl__operatorRoles, AccessControl_adminRoles, AccessControl__ADMIN_MASTER };

export { Identity__verifiedUsersforBuckets };

export { NonFungibleToken__name,
         NonFungibleToken__symbol,
         NonFungibleToken__certificatesCreatedCounter,
         NonFungibleToken__owners,
         NonFungibleToken__balances,
         NonFungibleToken__tokenApprovals,
         NonFungibleToken__operatorApprovals,
         NonFungibleToken__tokenToCertificate,
         NonFungibleToken__tokenToPrice,
         NonFungibleToken_Certificate,
         NonFungibleToken_Location,
         NonFungibleToken_Impact,
         NonFungibleToken_Source };

export { NFTPool__purchaseCounter, NFTPool__pool, NFTPool__tokenSold, NFTPool__nftOwnerCommitment }

///////////////////////////////////////////////////////////////////////////////
// PUBLIC STATE TOP LEVEL
///////////////////////////////////////////////////////////////////////////////

export { ZswapCoinPublicKey, ContractAddress, Either, ShieldedCoinInfo };

///////////////////////////////////////////////////////////////////////////////
// CIRCUITS GENERAL
///////////////////////////////////////////////////////////////////////////////

/**
* @description: Constructor circuit.
*
* @notice: All the initializing circuits are called here from the modules. Plus some initial settings.
*
* @requirements:
* - Calling all initialized circuits from modules.
* @param {Opaque<"string">} name_ - The name of the token.
* @param {Opaque<"string">} symbol_ - The symbol of the token.
*/
constructor(_name: Opaque<"string">, _symbol: Opaque<"string">) {
  AccessControl_initialize();
  Identity_initialize();
  NonFungibleToken_initialize(_name, _symbol);
  NFTPool_initialize();
}

///////////////////////////////////////////////////////////////////////////////
// CIRCUITS ACCESS CONTROL
///////////////////////////////////////////////////////////////////////////////

/**
* @description: Grants `roleId` to `account`
*
* @requirements:
* - Wrapper call
* @param {Bytes<32>} roleId - The role identifier.
* @param {Either<ZswapCoinPublicKey, ContractAddress>} account - The account to query.
* @return {[]} - Empty tuple.
*/
export circuit grantRole(roleId: Bytes<32>, account: Either<ZswapCoinPublicKey, ContractAddress>): [] {
  AccessControl_grantRole(roleId, account);
}

/**
* @description: Revokes `roleId` to `account`
*
* @requirements:
* - Wrapper call
* @param {Bytes<32>} roleId - The role identifier.
* @param {Either<ZswapCoinPublicKey, ContractAddress>} account - The account to query.
* @return {[]} - Empty tuple.
*/
export circuit revokeRole(roleId: Bytes<32>, account: Either<ZswapCoinPublicKey, ContractAddress>): [] {
  AccessControl_revokeRole(roleId, account);
}

/**
* @description: Renounces own RoleID
*
* @requirements:
* - Wrapper call
* @param {Bytes<32>} roleId - The role identifier.
* @return {[]} - Empty tuple.
*/
export circuit renounceRole(roleId: Bytes<32>,): [] {
  AccessControl_renounceRole(roleId);
}

/**
* @description: Sets `adminRole` as `roleId`'s admin role.
*
* @requirements:
* - Wrapper call
* @param {Bytes<32>} roleId - The role identifier.
* @param {Bytes<32>} adminRole - The admin role identifier.
*/
export circuit setRoleAdmin(roleId: Bytes<32>, adminRole: Bytes<32>): [] {
  AccessControl_setRoleAdmin(roleId, adminRole);
}

/**
* @description: Removes `adminRole` as `roleId`'s admin role.
*
* @requirements:
* - Wrapper call
* @param {Bytes<32>} roleId - The role identifier.
* @param {Bytes<32>} adminRole - The admin role identifier.
*/
export circuit removeRoleAdmin(roleId: Bytes<32>, adminRole: Bytes<32>): [] {
  AccessControl_removeRoleAdmin(roleId, adminRole);
}

/**
* @description: Reverts if `ownPublicKey()` is missing `roleId`.
*
* @requirements:
* - Wrapper call
* @param {Bytes<32>} roleId - The role identifier.
* @return {[]} - Empty tuple.
*/
export circuit assertOnlyRole(roleId: Bytes<32>): [] {
  AccessControl_assertOnlyRole(roleId);
}

/**
* @description: Pause Access Control calls.
*
* @notice: Only Admin master role can pause Access Control calls.
*
* @requirements:
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit pauseAccessControl(): [] {
  AccessControl_pauseAccessControl();
}

/**
* @description: Unpause Access Control calls.
*
* @notice: Only Admin master role can unpause Access Control calls.
*
* @requirements:
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit unpauseAccessControl(): [] {
  AccessControl_unpauseAccessControl();
}

///////////////////////////////////////////////////////////////////////////////
// CIRCUITS IDENTITY
///////////////////////////////////////////////////////////////////////////////

/**
* @description: This circuit verifies if the user creating the transaction is a member of the verified users set
*
* @requirements:
* - Wrapper call
*/
export circuit assertOwnVerification(): [] {
  Identity_assertOwnVerification();
}

/**
* @description: This circuit verifies if the user passed as parameter is a member of the verified users set
*
* @requirements:
* - Wrapper call
* @param {ZswapCoinPublicKey} user - User public key.
* @return {Boolean}
*/
export circuit isUserVerified(user: ZswapCoinPublicKey): Boolean {
  return Identity_isUserVerified(user);
}

/**
* @description: Includes a user in the verified users set
*
* @notice: Only verifier role can set users (role 3)
*
* @requirements:
* - The caller must have `Verifier Role`.
* - Wrapper call
* @param {ZswapCoinPublicKey} user - Zswap Coin public key of a new user.
* @return {[]} - Empty tuple.
*/
export circuit setUser(user: ZswapCoinPublicKey): [] {
  assertOnlyRole(3 as Field as Bytes<32>);
  Identity_setUser(user);
}

/**
* @description: Removes a user from the verified users set
*
* @notice: Only verifier role can remove users (role 3)
*
* @requirements:
* - The caller must have `Verifier Role`.
* - Wrapper call
* @param {ZswapCoinPublicKey} user - Zswap Coin public key of a new user.
* @return {[]} - Empty tuple.
*/
export circuit removeUser(user: ZswapCoinPublicKey): [] {
  assertOnlyRole(3 as Field as Bytes<32>);
  Identity_removeUser(user);
}

/**
* @description: Pause Identity calls.
*
* @notice: Only Admin master role can pause Identity calls.
*
* @requirements:
* - The caller must have `Admins master role`.
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit pauseIdentity(): [] {
  assertOnlyRole(default<Bytes<32>>);
  Identity_pauseIdentity();
}

/**
* @description: Unpause Identity calls.
*
* @notice: Only Admin master role can unpause Identity calls.
*
* @requirements:
* - The caller must have `Admins master role`.
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit unpauseIdentity(): [] {
  assertOnlyRole(default<Bytes<32>>);
  Identity_unpauseIdentity();
}

///////////////////////////////////////////////////////////////////////////////
// CIRCUITS TOKEN
///////////////////////////////////////////////////////////////////////////////

/**
* @description Returns the number of tokens in `owner`'s account.
*
* @requirements:
* - Wrapper call
* @param {Either<ZswapCoinPublicKey, ContractAddress>)} owner - The account to query.
* @return {Uint<128>} - The number of tokens in `owner`'s account.
*/
export circuit balanceOf(owner: Either<ZswapCoinPublicKey, ContractAddress>): Uint<128> {
  return NonFungibleToken_balanceOf(owner);
}

/**
* @description Returns the owner of the `tokenId` token.
*
* @requirements:
* - Wrapper call
* @param {Uint<128>} tokenId - The identifier for a token.
* @return {Either<ZswapCoinPublicKey, ContractAddress>} - The account that owns the token.
*/
export circuit ownerOf(tokenId: Uint<128>): Either<ZswapCoinPublicKey, ContractAddress> {
  return NonFungibleToken_ownerOf(tokenId);
}

/**
* @description Returns the token Certificate for the given `tokenId`.
*
* @requirements:
* - Wrapper call
* @param {Uint<128>} tokenId - The identifier for a token.
* @return {Certificate} - the token metadata
*/
export circuit tokenCertificate(tokenId: Uint<128>): NonFungibleToken_Certificate {
  return NonFungibleToken_tokenCertificate(tokenId);
}

/**
* @description Returns the token Price for the given `tokenId`.
*
* @requirements:
* - Wrapper call
* @param {Uint<128>} tokenId - The identifier for a token.
* @return {Uint<64>} - the price of the token
*/
export circuit tokenPrice(tokenId: Uint<128>): Uint<64> {
  return NonFungibleToken_tokenPrice(tokenId);
}

/**
* @description Mints `tokenId` and transfers it to `to`.
*
* @notice: Only Minter role (1) can mint.
*
* @requirements:
* - The caller must have `Minter role`.
* - Wrapper call
* @param {Either<ZswapCoinPublicKey, ContractAddress>} to - The target account
* @param {Uint<128>} tokenId - The token identifier
* @param {Certificate} tokenCertificate - The token metadata
* @param {Uint<64>} price - The token price
* @return {[]} - Empty tuple.
*/
export circuit mint(to: Either<ZswapCoinPublicKey, ContractAddress>,
                    tokenId: Uint<128>,
                    tokenCertificate: NonFungibleToken_Certificate,
                    price: Uint<64>
                    ): [] {
  assertOnlyRole(1 as Field as Bytes<32>);
  return NonFungibleToken_mint(to, tokenId, tokenCertificate, price);
}

/**
* @description Destroys an unsold `tokenId` (web2 ledger unlock for non-purchased tokens).
*
* @notice: Only Minter role (1) can burn unsold tokens (minter/burner combined role).
* Token must NOT be listed in the pool (unlist first via removeFromPool).
* Token must NOT be sold (sold tokens must be burned by commitment owner via burnPurchasedBatch).
*
* @requirements:
* - The caller must have `Minter role`.
* - Token must not be listed in the pool
* - Token must not be sold
* @param {Uint<128>} tokenId - The token to burn
* @return {[]} - Empty tuple.
*/
export circuit burn(tokenId: Uint<128>): [] {
  assertOnlyRole(1 as Field as Bytes<32>);

  // Token must not be listed in pool (unlist before burning)
  assert(!NFTPool__pool.member(disclose(tokenId)), "Token must be unlisted before burning");

  // Token must not be sold (sold tokens must be burned by commitment owner)
  if (NFTPool__tokenSold.member(disclose(tokenId))) {
    assert(!NFTPool__tokenSold.lookup(disclose(tokenId)), "Sold tokens must be burned by commitment owner");
  }

  return NonFungibleToken_burn(tokenId);
}

/**
* @description Sets the price for the given `tokenId`. Only PoolOperator role can update prices.
*
* @notice PoolOperator can update NFT prices at any time (even when listed in pool).
*
* @requirements:
* - The caller must have `PoolOperator role` (role 2).
* @param {Uint<128>} tokenId - The identifier of the token.
* @param {Uint<64>} price - The price of the token.
* @return {[]} - Empty tuple.
*/
export circuit setTokenPrice(tokenId: Uint<128>, price: Uint<64>): [] {
  assertOnlyRole(2 as Field as Bytes<32>);
  NonFungibleToken__setTokenPrice(tokenId, price);
}

/**
* @description: Pause Token calls.
*
* @notice: Only Admin master role can pause Token calls.
*
* @requirements:
* - The caller must have `Admins master role`.
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit pauseToken(): [] {
  assertOnlyRole(default<Bytes<32>>);
  NonFungibleToken_pauseToken();
}

/**
* @description: Unpause Token calls.
*
* @notice: Only Admin master role can unpause Token calls.
*
* @requirements:
* - The caller must have `Admins master role`.
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit unpauseToken(): [] {
  assertOnlyRole(default<Bytes<32>>);
  NonFungibleToken_unpauseToken();
}

///////////////////////////////////////////////////////////////////////////////
// CIRCUITS NFT POOL
///////////////////////////////////////////////////////////////////////////////

/**
* @description: Add an NFT to the pool for sale
*
* @notice: Only PoolOperator role (2) can add to pool.
* Cross-checks that the token exists in the NFT module.
*
* @requirements:
* - The caller must have `PoolOperator role`.
* - Token must exist in the NFT module
* - Wrapper call
* @param {Uint<128>} tokenId - The token ID to list
* @return {[]} - Empty tuple.
*/
export circuit addToPool(tokenId: Uint<128>): [] {
  assertOnlyRole(2 as Field as Bytes<32>);

  // Cross-check: token must exist in NFT module
  assert(NonFungibleToken__tokenToCertificate.member(disclose(tokenId)), "Token not found");

  NFTPool_addToPool(tokenId);
}

/**
* @description: Remove an NFT from the pool (delist)
*
* @notice: Only PoolOperator role (2) can remove from pool.
*
* @requirements:
* - The caller must have `PoolOperator role`.
* - Wrapper call
* @param {Uint<128>} tokenId - The token ID to delist
* @return {[]} - Empty tuple.
*/
export circuit removeFromPool(tokenId: Uint<128>): [] {
  assertOnlyRole(2 as Field as Bytes<32>);
  NFTPool_removeFromPool(tokenId);
}

/**
* @description: Purchase a single NFT from the pool
*
* @notice: Buyer must be identity-verified. Payment is received as a transparent shielded coin.
* The buyer's identity is hidden behind a hash commitment. The seller (NFT owner) is public.
*
* @requirements:
* - The caller must be identity-verified
* - Token must be listed in the pool
* - Payment coin value >= token price
* - Payment coin color must be native token
* - Receive the coin
* - Store payment in seller's balance
* - Delegate pool state updates to NFTPool module
* @param {Uint<128>} tokenId - The token ID to purchase
* @param {ShieldedCoinInfo} coin - The payment coin
* @return {Bytes<32>} ownerCommitment - The buyer's ownership commitment
*/
export circuit purchaseNFT(tokenId: Uint<128>, coin: ShieldedCoinInfo): Bytes<32> {
  // Verify buyer identity
  assertOwnVerification();

  // Get token price
  assert(NonFungibleToken__tokenToPrice.member(disclose(tokenId)), "Token price not set");
  const price = NonFungibleToken__tokenToPrice.lookup(disclose(tokenId));

  // Validate payment
  assert(coin.value >= price as Uint<128>, "Insufficient payment");
  assert(coin.color == nativeToken(), "Invalid coin provided");

  // Receive the payment
  receiveShielded(disclose(coin));

  // Get seller (current NFT owner)
  const seller = NonFungibleToken__owners.lookup(disclose(tokenId));

  // Store payment in seller's balance
  NFTPool_storeSellerPayment(seller, coin, price);

  // Execute pool purchase (marks sold, computes commitment, etc.)
  return NFTPool_purchaseNFT(tokenId);
}

///////////////////////////////////////////////////////////////////////////////
// BATCH HELPERS
///////////////////////////////////////////////////////////////////////////////

/**
* @description: Get token price or 0 for mock tokens (tokenId == 0)
*
* @notice: Used by batch purchase circuits to handle partial batches.
* Mock tokens (tokenId == 0) return price 0.
*
* @param {Uint<128>} tokenId - The token ID (0 for mock)
* @return {Uint<64>} price - The token price or 0
*/
export circuit _getBatchTokenPrice(tokenId: Uint<128>): Uint<64> {
  if (disclose(tokenId) != 0) {
    assert(NonFungibleToken__tokenToPrice.member(disclose(tokenId)), "Token price not set");
    return NonFungibleToken__tokenToPrice.lookup(disclose(tokenId));
  }
  return 0;
}

/**
* @description: Store seller payment for a real token (skips mock tokens)
*
* @notice: Used by batch purchase circuits. Skips when tokenId == 0.
*
* @param {Uint<128>} tokenId - The token ID (0 for mock)
* @param {ShieldedCoinInfo} coin - The payment coin
* @param {Uint<64>} price - The token price
* @return {[]} - Empty tuple.
*/
export circuit _storeBatchSellerPayment(tokenId: Uint<128>, coin: ShieldedCoinInfo, price: Uint<64>): [] {
  if (disclose(tokenId) != 0) {
    const seller = NonFungibleToken__owners.lookup(disclose(tokenId));
    NFTPool_storeSellerPayment(seller, coin, price);
  }
}

/**
* @description: Execute batch purchase for a real token (skips mock tokens)
*
* @notice: Used by batch purchase circuits. Skips when tokenId == 0.
*
* @param {Uint<128>} tokenId - The token ID (0 for mock)
* @param {Bytes<32>} ownerCommitment - The shared batch commitment
* @return {[]} - Empty tuple.
*/
export circuit _executeBatchPurchase(tokenId: Uint<128>, ownerCommitment: Bytes<32>): [] {
  if (disclose(tokenId) != 0) {
    NFTPool_purchaseNFTBatch(tokenId, ownerCommitment);
  }
}

///////////////////////////////////////////////////////////////////////////////
// BATCH PURCHASE CIRCUITS
///////////////////////////////////////////////////////////////////////////////

/**
* @description: Batch purchase of up to 5 NFTs with a single shared commitment
*
* @notice: All NFTs in the batch share ONE commitment. Mock tokens (tokenId == 0)
* are skipped. At least one real token must be included.
*
* @requirements:
* - The caller must be identity-verified
* - All real tokens must be listed in the pool
* - Payment >= sum of real token prices
* - Payment coin color must be native token
* @param {Uint<128>} tokenId1-5 - Token IDs (0 for mock/empty slot)
* @param {ShieldedCoinInfo} coin - The payment coin (covers total)
* @return {Bytes<32>} ownerCommitment - Single shared ownership commitment
*/
export circuit purchaseBatch5(
  tokenId1: Uint<128>,
  tokenId2: Uint<128>,
  tokenId3: Uint<128>,
  tokenId4: Uint<128>,
  tokenId5: Uint<128>,
  coin: ShieldedCoinInfo
): Bytes<32> {
  assertOwnVerification();

  // Get prices (0 for mock tokens)
  const price1 = _getBatchTokenPrice(tokenId1);
  const price2 = _getBatchTokenPrice(tokenId2);
  const price3 = _getBatchTokenPrice(tokenId3);
  const price4 = _getBatchTokenPrice(tokenId4);
  const price5 = _getBatchTokenPrice(tokenId5);

  const totalPrice = (price1 as Uint<128>) + (price2 as Uint<128>) + (price3 as Uint<128>)
                   + (price4 as Uint<128>) + (price5 as Uint<128>);

  assert(coin.value >= totalPrice, "Insufficient payment for batch");
  assert(coin.color == nativeToken(), "Invalid coin provided");

  receiveShielded(disclose(coin));

  // Store seller payments for real tokens
  _storeBatchSellerPayment(tokenId1, coin, price1);
  _storeBatchSellerPayment(tokenId2, coin, price2);
  _storeBatchSellerPayment(tokenId3, coin, price3);
  _storeBatchSellerPayment(tokenId4, coin, price4);
  _storeBatchSellerPayment(tokenId5, coin, price5);

  // Compute ONE commitment for all tokens in the batch
  const ownerCommitment = NFTPool_computeBatchCommitment();

  // Execute purchases for real tokens
  _executeBatchPurchase(tokenId1, ownerCommitment);
  _executeBatchPurchase(tokenId2, ownerCommitment);
  _executeBatchPurchase(tokenId3, ownerCommitment);
  _executeBatchPurchase(tokenId4, ownerCommitment);
  _executeBatchPurchase(tokenId5, ownerCommitment);

  return ownerCommitment;
}

/**
* @description: Batch purchase of up to 10 NFTs with a single shared commitment
*
* @notice: All NFTs in the batch share ONE commitment. Mock tokens (tokenId == 0)
* are skipped. At least one real token must be included.
*
* @requirements:
* - The caller must be identity-verified
* - All real tokens must be listed in the pool
* - Payment >= sum of real token prices
* @param {Uint<128>} tokenId1-10 - Token IDs (0 for mock/empty slot)
* @param {ShieldedCoinInfo} coin - The payment coin (covers total)
* @return {Bytes<32>} ownerCommitment - Single shared ownership commitment
*/
export circuit purchaseBatch10(
  tokenId1: Uint<128>,
  tokenId2: Uint<128>,
  tokenId3: Uint<128>,
  tokenId4: Uint<128>,
  tokenId5: Uint<128>,
  tokenId6: Uint<128>,
  tokenId7: Uint<128>,
  tokenId8: Uint<128>,
  tokenId9: Uint<128>,
  tokenId10: Uint<128>,
  coin: ShieldedCoinInfo
): Bytes<32> {
  assertOwnVerification();

  const price1 = _getBatchTokenPrice(tokenId1);
  const price2 = _getBatchTokenPrice(tokenId2);
  const price3 = _getBatchTokenPrice(tokenId3);
  const price4 = _getBatchTokenPrice(tokenId4);
  const price5 = _getBatchTokenPrice(tokenId5);
  const price6 = _getBatchTokenPrice(tokenId6);
  const price7 = _getBatchTokenPrice(tokenId7);
  const price8 = _getBatchTokenPrice(tokenId8);
  const price9 = _getBatchTokenPrice(tokenId9);
  const price10 = _getBatchTokenPrice(tokenId10);

  const totalPrice = (price1 as Uint<128>) + (price2 as Uint<128>) + (price3 as Uint<128>)
                   + (price4 as Uint<128>) + (price5 as Uint<128>) + (price6 as Uint<128>)
                   + (price7 as Uint<128>) + (price8 as Uint<128>) + (price9 as Uint<128>)
                   + (price10 as Uint<128>);

  assert(coin.value >= totalPrice, "Insufficient payment for batch");
  assert(coin.color == nativeToken(), "Invalid coin provided");

  receiveShielded(disclose(coin));

  _storeBatchSellerPayment(tokenId1, coin, price1);
  _storeBatchSellerPayment(tokenId2, coin, price2);
  _storeBatchSellerPayment(tokenId3, coin, price3);
  _storeBatchSellerPayment(tokenId4, coin, price4);
  _storeBatchSellerPayment(tokenId5, coin, price5);
  _storeBatchSellerPayment(tokenId6, coin, price6);
  _storeBatchSellerPayment(tokenId7, coin, price7);
  _storeBatchSellerPayment(tokenId8, coin, price8);
  _storeBatchSellerPayment(tokenId9, coin, price9);
  _storeBatchSellerPayment(tokenId10, coin, price10);

  const ownerCommitment = NFTPool_computeBatchCommitment();

  _executeBatchPurchase(tokenId1, ownerCommitment);
  _executeBatchPurchase(tokenId2, ownerCommitment);
  _executeBatchPurchase(tokenId3, ownerCommitment);
  _executeBatchPurchase(tokenId4, ownerCommitment);
  _executeBatchPurchase(tokenId5, ownerCommitment);
  _executeBatchPurchase(tokenId6, ownerCommitment);
  _executeBatchPurchase(tokenId7, ownerCommitment);
  _executeBatchPurchase(tokenId8, ownerCommitment);
  _executeBatchPurchase(tokenId9, ownerCommitment);
  _executeBatchPurchase(tokenId10, ownerCommitment);

  return ownerCommitment;
}

/**
* @description: Batch purchase of up to 20 NFTs with a single shared commitment
*
* @notice: All NFTs in the batch share ONE commitment. Mock tokens (tokenId == 0)
* are skipped. At least one real token must be included.
*
* @requirements:
* - The caller must be identity-verified
* - All real tokens must be listed in the pool
* - Payment >= sum of real token prices
* @param {Uint<128>} tokenId1-20 - Token IDs (0 for mock/empty slot)
* @param {ShieldedCoinInfo} coin - The payment coin (covers total)
* @return {Bytes<32>} ownerCommitment - Single shared ownership commitment
*/
export circuit purchaseBatch20(
  tokenId1: Uint<128>,
  tokenId2: Uint<128>,
  tokenId3: Uint<128>,
  tokenId4: Uint<128>,
  tokenId5: Uint<128>,
  tokenId6: Uint<128>,
  tokenId7: Uint<128>,
  tokenId8: Uint<128>,
  tokenId9: Uint<128>,
  tokenId10: Uint<128>,
  tokenId11: Uint<128>,
  tokenId12: Uint<128>,
  tokenId13: Uint<128>,
  tokenId14: Uint<128>,
  tokenId15: Uint<128>,
  tokenId16: Uint<128>,
  tokenId17: Uint<128>,
  tokenId18: Uint<128>,
  tokenId19: Uint<128>,
  tokenId20: Uint<128>,
  coin: ShieldedCoinInfo
): Bytes<32> {
  assertOwnVerification();

  const price1 = _getBatchTokenPrice(tokenId1);
  const price2 = _getBatchTokenPrice(tokenId2);
  const price3 = _getBatchTokenPrice(tokenId3);
  const price4 = _getBatchTokenPrice(tokenId4);
  const price5 = _getBatchTokenPrice(tokenId5);
  const price6 = _getBatchTokenPrice(tokenId6);
  const price7 = _getBatchTokenPrice(tokenId7);
  const price8 = _getBatchTokenPrice(tokenId8);
  const price9 = _getBatchTokenPrice(tokenId9);
  const price10 = _getBatchTokenPrice(tokenId10);
  const price11 = _getBatchTokenPrice(tokenId11);
  const price12 = _getBatchTokenPrice(tokenId12);
  const price13 = _getBatchTokenPrice(tokenId13);
  const price14 = _getBatchTokenPrice(tokenId14);
  const price15 = _getBatchTokenPrice(tokenId15);
  const price16 = _getBatchTokenPrice(tokenId16);
  const price17 = _getBatchTokenPrice(tokenId17);
  const price18 = _getBatchTokenPrice(tokenId18);
  const price19 = _getBatchTokenPrice(tokenId19);
  const price20 = _getBatchTokenPrice(tokenId20);

  const totalPrice = (price1 as Uint<128>) + (price2 as Uint<128>) + (price3 as Uint<128>)
                   + (price4 as Uint<128>) + (price5 as Uint<128>) + (price6 as Uint<128>)
                   + (price7 as Uint<128>) + (price8 as Uint<128>) + (price9 as Uint<128>)
                   + (price10 as Uint<128>) + (price11 as Uint<128>) + (price12 as Uint<128>)
                   + (price13 as Uint<128>) + (price14 as Uint<128>) + (price15 as Uint<128>)
                   + (price16 as Uint<128>) + (price17 as Uint<128>) + (price18 as Uint<128>)
                   + (price19 as Uint<128>) + (price20 as Uint<128>);

  assert(coin.value >= totalPrice, "Insufficient payment for batch");
  assert(coin.color == nativeToken(), "Invalid coin provided");

  receiveShielded(disclose(coin));

  _storeBatchSellerPayment(tokenId1, coin, price1);
  _storeBatchSellerPayment(tokenId2, coin, price2);
  _storeBatchSellerPayment(tokenId3, coin, price3);
  _storeBatchSellerPayment(tokenId4, coin, price4);
  _storeBatchSellerPayment(tokenId5, coin, price5);
  _storeBatchSellerPayment(tokenId6, coin, price6);
  _storeBatchSellerPayment(tokenId7, coin, price7);
  _storeBatchSellerPayment(tokenId8, coin, price8);
  _storeBatchSellerPayment(tokenId9, coin, price9);
  _storeBatchSellerPayment(tokenId10, coin, price10);
  _storeBatchSellerPayment(tokenId11, coin, price11);
  _storeBatchSellerPayment(tokenId12, coin, price12);
  _storeBatchSellerPayment(tokenId13, coin, price13);
  _storeBatchSellerPayment(tokenId14, coin, price14);
  _storeBatchSellerPayment(tokenId15, coin, price15);
  _storeBatchSellerPayment(tokenId16, coin, price16);
  _storeBatchSellerPayment(tokenId17, coin, price17);
  _storeBatchSellerPayment(tokenId18, coin, price18);
  _storeBatchSellerPayment(tokenId19, coin, price19);
  _storeBatchSellerPayment(tokenId20, coin, price20);

  const ownerCommitment = NFTPool_computeBatchCommitment();

  _executeBatchPurchase(tokenId1, ownerCommitment);
  _executeBatchPurchase(tokenId2, ownerCommitment);
  _executeBatchPurchase(tokenId3, ownerCommitment);
  _executeBatchPurchase(tokenId4, ownerCommitment);
  _executeBatchPurchase(tokenId5, ownerCommitment);
  _executeBatchPurchase(tokenId6, ownerCommitment);
  _executeBatchPurchase(tokenId7, ownerCommitment);
  _executeBatchPurchase(tokenId8, ownerCommitment);
  _executeBatchPurchase(tokenId9, ownerCommitment);
  _executeBatchPurchase(tokenId10, ownerCommitment);
  _executeBatchPurchase(tokenId11, ownerCommitment);
  _executeBatchPurchase(tokenId12, ownerCommitment);
  _executeBatchPurchase(tokenId13, ownerCommitment);
  _executeBatchPurchase(tokenId14, ownerCommitment);
  _executeBatchPurchase(tokenId15, ownerCommitment);
  _executeBatchPurchase(tokenId16, ownerCommitment);
  _executeBatchPurchase(tokenId17, ownerCommitment);
  _executeBatchPurchase(tokenId18, ownerCommitment);
  _executeBatchPurchase(tokenId19, ownerCommitment);
  _executeBatchPurchase(tokenId20, ownerCommitment);

  return ownerCommitment;
}

/**
* @description: Seller withdraws accumulated payment balance
*
* @notice: Caller (seller) withdraws their earnings via sendShielded.
*
* @requirements:
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit withdrawSellerFunds(): [] {
  NFTPool_withdrawSellerFunds();
}

/**
* @description: Proof of NFT ownership
*
* @notice: Delegates to NFTPool module.
*
* @requirements:
* - Wrapper call
* @param {Bytes<32>} ownerCommitment - The ownership commitment
* @param {Bytes<32>} challenge - The challenge for ZK proof
* @return {[]} - Empty tuple.
*/
export circuit proofOwnership(ownerCommitment: Bytes<32>, challenge: Bytes<32>): [] {
  return NFTPool_proofOwnership(ownerCommitment, challenge);
}

/**
* @description: Pause NFTPool calls.
*
* @notice: Only Admin master role can pause NFTPool calls.
*
* @requirements:
* - The caller must have `Admins master role`.
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit pauseNFTPool(): [] {
  assertOnlyRole(default<Bytes<32>>);
  NFTPool_pauseNFTPool();
}

/**
* @description: Unpause NFTPool calls.
*
* @notice: Only Admin master role can unpause NFTPool calls.
*
* @requirements:
* - The caller must have `Admins master role`.
* - Wrapper call
* @return {[]} - Empty tuple.
*/
export circuit unpauseNFTPool(): [] {
  assertOnlyRole(default<Bytes<32>>);
  NFTPool_unpauseNFTPool();
}

///////////////////////////////////////////////////////////////////////////////
// BURN PURCHASED TOKENS (BUYER-OWNED VIA COMMITMENT)
///////////////////////////////////////////////////////////////////////////////

/**
* @description: Burn a single purchased token after verifying it belongs to the commitment.
*
* @notice: Used by burnPurchasedBatch circuits. Skips when tokenId == 0 (mock).
* Verifies the token's stored commitment matches, cleans up pool state, then burns the NFT.
*
* @param {Uint<128>} tokenId - The token ID (0 for mock)
* @param {Bytes<32>} ownerCommitment - The buyer's commitment
* @return {[]} - Empty tuple.
*/
export circuit _burnPurchasedToken(tokenId: Uint<128>, ownerCommitment: Bytes<32>): [] {
  if (disclose(tokenId) != 0) {
    // Verify this token was purchased and belongs to this commitment
    assert(NFTPool__nftOwnerCommitment.member(disclose(tokenId)), "Token not purchased");
    const storedCommitment = NFTPool__nftOwnerCommitment.lookup(disclose(tokenId));
    assert(storedCommitment == disclose(ownerCommitment), "Token not owned by this commitment");

    // Clean up pool state (sold status, commitment mapping)
    NFTPool_cleanupSoldToken(tokenId);

    // Burn the NFT
    NonFungibleToken_burn(tokenId);
  }
}

/**
* @description: Burn up to 5 purchased tokens owned by the caller via commitment.
*
* @notice: The buyer must prove ownership of the commitment atomically within this circuit.
* The challenge is stored for audit. Mock tokens (tokenId == 0) are skipped.
* This represents unlocking the digital assets on the web2 ledger.
*
* @requirements:
* - Caller must be the owner of the commitment (ZK proof via witness nonce)
* - Each real token must belong to this commitment
* - Challenge is stored for audit trail
* @param {Bytes<32>} ownerCommitment - The buyer's ownership commitment
* @param {Uint<128>} tokenId1-5 - Token IDs (0 for mock/empty slot)
* @param {Bytes<32>} challenge - The challenge for ZK proof / audit trail
* @return {[]} - Empty tuple.
*/
export circuit burnPurchasedBatch5(
  ownerCommitment: Bytes<32>,
  tokenId1: Uint<128>,
  tokenId2: Uint<128>,
  tokenId3: Uint<128>,
  tokenId4: Uint<128>,
  tokenId5: Uint<128>,
  challenge: Bytes<32>
): [] {
  // Prove ownership of the commitment and store challenge
  NFTPool_proofOwnership(ownerCommitment, challenge);

  // Burn each real token
  _burnPurchasedToken(tokenId1, ownerCommitment);
  _burnPurchasedToken(tokenId2, ownerCommitment);
  _burnPurchasedToken(tokenId3, ownerCommitment);
  _burnPurchasedToken(tokenId4, ownerCommitment);
  _burnPurchasedToken(tokenId5, ownerCommitment);
}

/**
* @description: Burn up to 10 purchased tokens owned by the caller via commitment.
*
* @notice: Same as burnPurchasedBatch5 but for up to 10 tokens.
*
* @param {Bytes<32>} ownerCommitment - The buyer's ownership commitment
* @param {Uint<128>} tokenId1-10 - Token IDs (0 for mock/empty slot)
* @param {Bytes<32>} challenge - The challenge for ZK proof / audit trail
* @return {[]} - Empty tuple.
*/
export circuit burnPurchasedBatch10(
  ownerCommitment: Bytes<32>,
  tokenId1: Uint<128>,
  tokenId2: Uint<128>,
  tokenId3: Uint<128>,
  tokenId4: Uint<128>,
  tokenId5: Uint<128>,
  tokenId6: Uint<128>,
  tokenId7: Uint<128>,
  tokenId8: Uint<128>,
  tokenId9: Uint<128>,
  tokenId10: Uint<128>,
  challenge: Bytes<32>
): [] {
  NFTPool_proofOwnership(ownerCommitment, challenge);

  _burnPurchasedToken(tokenId1, ownerCommitment);
  _burnPurchasedToken(tokenId2, ownerCommitment);
  _burnPurchasedToken(tokenId3, ownerCommitment);
  _burnPurchasedToken(tokenId4, ownerCommitment);
  _burnPurchasedToken(tokenId5, ownerCommitment);
  _burnPurchasedToken(tokenId6, ownerCommitment);
  _burnPurchasedToken(tokenId7, ownerCommitment);
  _burnPurchasedToken(tokenId8, ownerCommitment);
  _burnPurchasedToken(tokenId9, ownerCommitment);
  _burnPurchasedToken(tokenId10, ownerCommitment);
}

/**
* @description: Burn up to 20 purchased tokens owned by the caller via commitment.
*
* @notice: Same as burnPurchasedBatch5 but for up to 20 tokens.
*
* @param {Bytes<32>} ownerCommitment - The buyer's ownership commitment
* @param {Uint<128>} tokenId1-20 - Token IDs (0 for mock/empty slot)
* @param {Bytes<32>} challenge - The challenge for ZK proof / audit trail
* @return {[]} - Empty tuple.
*/
export circuit burnPurchasedBatch20(
  ownerCommitment: Bytes<32>,
  tokenId1: Uint<128>,
  tokenId2: Uint<128>,
  tokenId3: Uint<128>,
  tokenId4: Uint<128>,
  tokenId5: Uint<128>,
  tokenId6: Uint<128>,
  tokenId7: Uint<128>,
  tokenId8: Uint<128>,
  tokenId9: Uint<128>,
  tokenId10: Uint<128>,
  tokenId11: Uint<128>,
  tokenId12: Uint<128>,
  tokenId13: Uint<128>,
  tokenId14: Uint<128>,
  tokenId15: Uint<128>,
  tokenId16: Uint<128>,
  tokenId17: Uint<128>,
  tokenId18: Uint<128>,
  tokenId19: Uint<128>,
  tokenId20: Uint<128>,
  challenge: Bytes<32>
): [] {
  NFTPool_proofOwnership(ownerCommitment, challenge);

  _burnPurchasedToken(tokenId1, ownerCommitment);
  _burnPurchasedToken(tokenId2, ownerCommitment);
  _burnPurchasedToken(tokenId3, ownerCommitment);
  _burnPurchasedToken(tokenId4, ownerCommitment);
  _burnPurchasedToken(tokenId5, ownerCommitment);
  _burnPurchasedToken(tokenId6, ownerCommitment);
  _burnPurchasedToken(tokenId7, ownerCommitment);
  _burnPurchasedToken(tokenId8, ownerCommitment);
  _burnPurchasedToken(tokenId9, ownerCommitment);
  _burnPurchasedToken(tokenId10, ownerCommitment);
  _burnPurchasedToken(tokenId11, ownerCommitment);
  _burnPurchasedToken(tokenId12, ownerCommitment);
  _burnPurchasedToken(tokenId13, ownerCommitment);
  _burnPurchasedToken(tokenId14, ownerCommitment);
  _burnPurchasedToken(tokenId15, ownerCommitment);
  _burnPurchasedToken(tokenId16, ownerCommitment);
  _burnPurchasedToken(tokenId17, ownerCommitment);
  _burnPurchasedToken(tokenId18, ownerCommitment);
  _burnPurchasedToken(tokenId19, ownerCommitment);
  _burnPurchasedToken(tokenId20, ownerCommitment);
}
