{
  "name": "@eddalabs/private-buyer-cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test-undeployed": "vitest run private-buyer.test.ts",
    "test-preview": "RUN_ENV_TESTS=true TEST_ENV=preview vitest run private-buyer.test.ts",
    "test-preprod": "RUN_ENV_TESTS=true TEST_ENV=preprod vitest run private-buyer.test.ts",
    "tui-undeployed": "bun src/tui_standalone.ts",
    "tui-preview": "bun src/tui_preview.ts",
    "tui-preprod": "bun src/tui_preprod.ts",
    "tui-preview-no-docker": "bun src/tui_preview_no_docker.ts",
    "tui-preprod-no-docker": "bun src/tui_preprod_no_docker.ts",
    "tui-standalone-no-docker": "bun src/tui_standalone_no_docker.ts",
    "auto-deploy": "bun src/auto-deploy.ts",
    "setup-undeployed": "bun src/setup/standalone.ts",
    "instances-undeployed": "docker compose -f standalone.yml up",
    "proof-server": "docker compose -f proof-server.yml up",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "private-provider-testing": "vitest run src/test/private-provider.test.ts",
    "public-provider-testing": "vitest run src/test/public-provider.test.ts",
    "zk-provider-testing": "vitest run src/test/zk-provider.test.ts",
    "indexer-client-testing": "vitest run src/test/indexer-client.test.ts",
    "wallet-testing": "vitest run src/test/wallet.test.ts"
  },
  "dependencies": {
    "@eddalabs/private-buyer-contract": "*"
  }
}
