{
  "name": "@eddalabs/mini-private-buyer-contract",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3"
  },
  "scripts": {
    "compact-full": "compact compile +0.30.0 src/mini-private-buyer.compact src/managed/mini-private-buyer",
    "compact": "compact compile --skip-zk +0.30.0 src/mini-private-buyer.compact src/managed/mini-private-buyer",
    "test": "vitest run",
    "test:compile": "pnpm compact && vitest run",
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./src/managed ./dist/managed && cp ./src/mini-private-buyer.compact ./dist",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
