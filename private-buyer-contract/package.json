{
  "name": "@eddalabs/mini-private-buyer-contract",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "compact-fast": "compact compile --skip-zk +0.28.0 src/mini-private-buyer.compact src/managed/mini-private-buyer",
    "compact": "compact compile +0.28.0 src/mini-private-buyer.compact src/managed/mini-private-buyer",
    "test": "vitest run",
    "test:compile": "npm run compact && vitest run",
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./src/managed ./dist/managed && cp ./src/mini-private-buyer.compact ./dist",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
